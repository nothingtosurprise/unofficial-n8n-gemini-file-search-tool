# Integration Test Environment Configuration
# Copy this file to .env.test and fill in your test credentials

# Required: Your Gemini API key for testing
# Get this from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY_TEST=your_gemini_api_key_here

# Optional: API Base URL (defaults to Gemini API v1beta)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional: API request timeout in milliseconds (default: 60000)
# TEST_TIMEOUT=60000

# Optional: Maximum API retry attempts (default: 3)
# TEST_MAX_RETRIES=3

# Optional: Prefix for test stores to make them identifiable (default: test-n8n-integration-)
# TEST_STORE_PREFIX=my-test-integration-

# Optional: Auto-cleanup test resources after tests (default: true)
# Set to 'false' to keep test resources for manual inspection
# CLEANUP_ON_COMPLETE=true

# Optional: Node environment for testing
# NODE_ENV=test
