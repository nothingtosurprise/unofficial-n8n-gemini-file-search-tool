{
  "name": "n8n-nodes-gemini-file-search",
  "version": "1.0.0",
  "description": "n8n community nodes for Google Gemini File Search Tool API - Build powerful document search and RAG systems with AI-powered semantic search",
  "keywords": [
    "n8n",
    "n8n-nodes",
    "n8n-community-node-package",
    "gemini",
    "google",
    "google-ai",
    "file-search",
    "document-search",
    "rag",
    "semantic-search",
    "ai",
    "machine-learning",
    "document-management",
    "vector-search"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mbradaschia/n8n-nodes-gemini-file-search-tool",
  "bugs": {
    "url": "https://github.com/mbradaschia/n8n-nodes-gemini-file-search-tool/issues"
  },
  "author": {
    "name": "Brada"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbradaschia/n8n-nodes-gemini-file-search-tool.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "copyfiles -u 1 \"nodes/**/*.{png,svg,json}\" dist/",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:e2e": "jest --testPathPattern=test/e2e",
    "test:performance": "jest --testPathPattern=test/performance --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GeminiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GeminiFileSearchStores/GeminiFileSearchStores.node.js",
      "dist/nodes/GeminiFileSearchDocuments/GeminiFileSearchDocuments.node.js"
    ]
  },
  "dependencies": {
    "n8n-core": "^1.0.0",
    "n8n-workflow": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "nock": "^13.5.6",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
